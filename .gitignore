# Python bytecode and extensions
__pycache__/
*.py[codz]
*.so

# Build / distribution
build/
dist/
*.egg-info/

# Test and coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Linters and type checkers
.mypy_cache/
.ruff_cache/

# Environments
.env
.venv/
venv/
env/
ENV/

# PyCharm
.idea/

# Project data (gitignored, regenerable from pipeline). data/parquet/ is
# selectively allowed below so the seven cleaned-stage-2 parquets ship in-tree
# and a fresh clone can run from stage 3 onward without hitting histdata.com.
data/*
!data/parquet/
datasets/
features/
labels/
eda/
output/

# Binary data formats (catches model checkpoints under models/ and scalers/).
# The parquets under data/parquet/ are explicitly re-included.
*.parquet
*.pkl
*.pt
!data/parquet/*.parquet

# Project local artefacts
tests/
backtest/reports/
*.html
.gitattributes

# bootstrap.py runtime artefacts
bootstrap.log
.bootstrap_state.json
requirements.lock.txt

# Allow demo assets and the sample report to ship under docs/assets/
!docs/assets/*.html
!docs/assets/*.png

# Inspection scripts kept local
eda_split_readiness.py

# Claude code
.claude/

.DS_Store